# .env.example
# Copy to .env and fill in real values before running docker compose
# NEVER commit .env to git

# -----------------------------------------------------------------------------
# Vault
# -----------------------------------------------------------------------------
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=your-vault-root-token

# -----------------------------------------------------------------------------
# API keys (loaded into Vault by vault-init container)
# -----------------------------------------------------------------------------
CLAUDE_API_KEY=sk-ant-...
VIRUSTOTAL_API_KEY=...
ABUSEIPDB_API_KEY=...
ALIENVAULT_API_KEY=...

# Optional — GreyNoise excluded (requires paid subscription)
# GREYNOISE_API_KEY=...

# Optional — Shodan InternetDB is free, no API key required
# SHODAN_API_KEY=...

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Root password (used by the postgres container itself)
POSTGRES_PASSWORD=your-postgres-root-password

# App password (used by the app services to connect)
DB_PASSWORD=your-db-password

# Per-user passwords (created by migration 002, one per service)
CLASSIFIER_DB_PASSWORD=your-classifier-db-password
PROFILER_DB_PASSWORD=your-profiler-db-password
LOGGER_DB_PASSWORD=your-logger-db-password
AGENT_DB_PASSWORD=your-agent-db-password
DASHBOARD_DB_PASSWORD=your-dashboard-db-password
MIGRATE_DB_PASSWORD=your-migrate-db-password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=your-redis-password

# -----------------------------------------------------------------------------
# Service-to-service auth (used by guardrails sidecar)
# -----------------------------------------------------------------------------
SERVICE_TOKEN=your-service-token
